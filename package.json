{
  "name": "@experiwall/cli",
  "version": "0.1.0",
  "description": "CLI for the Experiwall Management API — manage experiments, view analytics, and configure projects from your terminal",
  "type": "module",
  "bin": {
    "experiwall": "dist/index.js",
    "ew": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "experiwall",
    "ab-testing",
    "experiments",
    "cli",
    "experimentation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcelo-earth/experiwall-cli"
  },
  "homepage": "https://experiwall.com",
  "bugs": {
    "url": "https://github.com/marcelo-earth/experiwall-cli/issues"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.5.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.0.0",
    "update-notifier": "^7.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/update-notifier": "^6.0.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
